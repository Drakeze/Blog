# ─────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT OVERRIDES — copy this to .env.local
# .env.local is NOT committed to git and overrides .env
# ─────────────────────────────────────────────────────────────

# Use a local MongoDB or a separate Atlas cluster for dev
# (avoids polluting production data)
DATABASE_URL="mongodb://localhost:27017/blog_dev"
# OR: use Atlas but with a dev cluster connection string

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Clerk ────────────────────────────────────────────────────
# Create a FREE Development app at dashboard.clerk.com
# Development apps use pk_test_ keys — no custom domain needed
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_dev_key_here"
CLERK_SECRET_KEY="sk_test_your_dev_secret_here"

# Your email so you have admin access locally
CLERK_ADMIN_EMAILS="your@email.com"

# ── Resend ───────────────────────────────────────────────────
# Use Resend's test mode or leave blank to skip email sending
RESEND_API_KEY="re_test_..."
RESEND_FROM_EMAIL="Blog <onboarding@resend.dev>"

# Disable auto-email on publish while developing
AUTO_SEND_POST_EMAILS="false"
