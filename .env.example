# Core
DATABASE_URL=mongodb://localhost:27017/blog_db
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
CLERK_ADMIN_EMAILS=
CLERK_ADMIN_USER_IDS=

# Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=Blog <updates@example.com>
RESEND_REPLY_TO_EMAIL=
AUTO_SEND_POST_EMAILS=false

# External API (for automated posting via Claude / scripts)
# Generate with: openssl rand -hex 32
BLOG_API_KEY=

# Draft post API (for creating drafts programmatically, e.g. from Claude)
# Generate with: openssl rand -hex 32
DRAFT_API_SECRET=

# Cloudflare R2 image storage
# Create bucket at dash.cloudflare.com → R2 → Create bucket
# Create API token at R2 → Manage R2 API Tokens (Object Read & Write)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# Reddit integration
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:blog-sync:v1.0 (by /u/your_reddit_username)
REDDIT_USERNAME=
